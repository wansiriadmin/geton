---
import BaseLayout from '~/layouts/BaseLayout.astro';
---

<BaseLayout title="ติดต่อเก็ตออน — GET ON Rollers">
  <!-- Yellow strip header -->
  <div class="yellow-strip">
    <div class="max-w-7xl mx-auto flex flex-wrap items-baseline justify-between gap-2">
      <h1 class="text-2xl md:text-3xl font-black">ติดต่อเรา</h1>
      <nav class="text-sm font-medium">
        <a href="/" class="hover:underline">หน้าแรก</a>
        <span class="mx-2">/</span>
        <span class="font-bold">ติดต่อ</span>
      </nav>
    </div>
  </div>

  <!-- Contact cards -->
  <section class="bg-brand-dark">
    <div class="max-w-7xl mx-auto px-4 md:px-8 py-20">
      <div class="grid gap-6 md:grid-cols-3">
        <a
          href="tel:0896777977"
          class="group bg-brand-dark-soft border-2 border-transparent hover:border-brand-yellow p-8 text-center transition-colors"
        >
          <div class="w-14 h-14 mx-auto rounded-full bg-brand-yellow text-brand-dark flex items-center justify-center mb-5">
            <svg class="w-7 h-7" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z"/></svg>
          </div>
          <h2 class="font-bold text-xl mb-1">โทรศัพท์</h2>
          <p class="text-brand-yellow font-bold text-lg">089 6777977</p>
        </a>

        <a
          href="https://page.line.me/geton"
          target="_blank"
          rel="noopener"
          class="group bg-brand-dark-soft border-2 border-transparent hover:border-brand-yellow p-8 text-center transition-colors"
        >
          <div class="w-14 h-14 mx-auto rounded-full bg-green-500 text-white flex items-center justify-center mb-5">
            <svg class="w-7 h-7" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M19.365 9.863c.349 0 .63.285.63.631 0 .345-.281.63-.63.63h-1.755v1.125h1.755c.349 0 .63.283.63.63 0 .344-.281.629-.63.629h-2.386c-.345 0-.627-.285-.627-.629V8.108c0-.345.282-.63.63-.63h2.386c.346 0 .627.285.627.63 0 .349-.281.63-.63.63h-1.755v1.125h1.755zm-3.855 3.016c0 .27-.174.51-.432.596-.064.021-.133.031-.199.031-.211 0-.391-.09-.51-.25l-2.443-3.317v2.94c0 .344-.279.629-.631.629-.346 0-.626-.285-.626-.629V8.108c0-.27.173-.51.43-.595.06-.023.136-.033.194-.033.195 0 .375.104.495.254l2.462 3.33V8.108c0-.345.282-.63.63-.63.345 0 .63.285.63.63v4.771zm-5.741 0c0 .344-.282.629-.631.629-.345 0-.627-.285-.627-.629V8.108c0-.345.282-.63.63-.63.346 0 .628.285.628.63v4.771zm-2.466.629H4.917c-.345 0-.63-.285-.63-.629V8.108c0-.345.285-.63.63-.63.348 0 .63.285.63.63v4.141h1.756c.348 0 .629.283.629.63 0 .344-.282.629-.629.629M24 10.314C24 4.943 18.615.572 12 .572S0 4.943 0 10.314c0 4.811 4.27 8.842 10.035 9.608.391.082.923.258 1.058.59.12.301.079.766.038 1.08l-.164 1.02c-.045.301-.24 1.186 1.049.645 1.291-.539 6.916-4.078 9.436-6.975C23.176 14.393 24 12.458 24 10.314"/></svg>
          </div>
          <h2 class="font-bold text-xl mb-1">LINE Official</h2>
          <p class="text-brand-yellow font-bold text-lg">@geton</p>
        </a>

        <a
          href="mailto:info@geton.co.th"
          class="group bg-brand-dark-soft border-2 border-transparent hover:border-brand-yellow p-8 text-center transition-colors"
        >
          <div class="w-14 h-14 mx-auto rounded-full bg-brand-yellow text-brand-dark flex items-center justify-center mb-5">
            <svg class="w-7 h-7" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M20 4H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"/></svg>
          </div>
          <h2 class="font-bold text-xl mb-1">อีเมล</h2>
          <p class="text-brand-yellow font-bold text-lg">info@geton.co.th</p>
        </a>
      </div>
    </div>
  </section>

  <!-- Address & hours -->
  <section class="bg-white text-brand-dark">
    <div class="max-w-7xl mx-auto px-4 md:px-8 py-20 grid gap-12 md:grid-cols-2">
      <div>
        <h2 class="text-2xl md:text-3xl font-black mb-5">ที่อยู่</h2>
        <p class="text-gray-600 text-lg leading-relaxed">
          ผู้ผลิต และ จำหน่าย ผลิตภัณฑ์ ล้อบานเลื่อน ล้อรางแขวน
          ภายใต้เครื่องหมายการค้า "Get On"
        </p>
        <p class="mt-4 font-bold text-lg">
          สำนักงานใหญ่: ถนนสุรวงศ์ เขตบางรัก กรุงเทพมหานคร
        </p>
      </div>
      <div>
        <h2 class="text-2xl md:text-3xl font-black mb-5">เวลาทำการ</h2>
        <ul class="space-y-3 text-lg">
          <li class="flex justify-between border-b border-gray-200 pb-2">
            <span>จันทร์ - ศุกร์</span><span class="font-bold">8:00 - 18:00 น.</span>
          </li>
          <li class="flex justify-between border-b border-gray-200 pb-2">
            <span>เสาร์</span><span class="font-bold">9:00 - 16:00 น.</span>
          </li>
          <li class="flex justify-between border-b border-gray-200 pb-2">
            <span>อาทิตย์ / วันหยุดนักขัตฤกษ์</span><span class="font-bold text-gray-400">ปิดทำการ</span>
          </li>
        </ul>
      </div>
    </div>
  </section>
</BaseLayout>
